# === Telegram ===
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=483078446

# === LLM Providers (fallback order: groq → sambanova → google → deepseek) ===
GROQ_API_KEY=
GROQ_MODEL=compound-beta-mini
GROQ_BASE_URL=https://api.groq.com

SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-pro
GOOGLE_API_VERSION=v1

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === Search ===
SERPER_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
SEARCH_ANALYSIS_PROVIDER=hybrid
SEARCH_ANALYSIS_RESULTS_PER_QUERY=2
SEARCH_ANALYSIS_MAX_SNIPPETS=4
SEARCH_MAX_SITES=4
GOOGLE_BACKOFF_SECONDS=900

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://user:pass@localhost:5432/spotr_bot

# === Logging ===
APP_LOG_LEVEL=INFO
EXTERNAL_LOG_LEVEL=ERROR
QUIET_E2E_SUMMARY=false

# === Paywall ===
ENABLE_PAYWALL=false
MAX_FREE_REQUESTS=3

# === Payments (stubs) ===
SUBSCRIPTION_PRICE_RUB=0
SUBSCRIPTION_PRICE_USDT=0
SUBSCRIPTION_PRICE_STARS=0
SUBSCRIPTION_DAYS=30
