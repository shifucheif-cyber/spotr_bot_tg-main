TELEGRAM_TOKEN=your_telegram_bot_token_here
LLM_PROVIDER=groq
APP_LOG_LEVEL=WARNING
EXTERNAL_LOG_LEVEL=ERROR
QUIET_E2E_SUMMARY=false
# LLM_PROVIDER can be 'google' or 'groq'

# If using Google (Gemini)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-1.5
GOOGLE_API_VERSION=v1
TAVILY_API_KEY=your_tavily_api_key_here
EXA_API_KEY=your_exa_api_key_here
SERPER_API_KEY=your_serper_api_key_here
EXPERIMENT_SEARCH_PROVIDER=tavily
SEARCH_ANALYSIS_PROVIDER=hybrid
SEARCH_ANALYSIS_RESULTS_PER_QUERY=2
SEARCH_ANALYSIS_MAX_SNIPPETS=4

# If using Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=compound-beta-mini
GROQ_BASE_URL=

# If using SambaNova
SAMBANOVA_API_KEY=your_sambanova_api_key_here
SAMBANOVA_MODEL=Meta-Llama-3.3-70B-Instruct
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1

# If using DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
